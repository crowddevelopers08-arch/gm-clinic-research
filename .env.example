# ----------------------------------------------------------------------------
# Neon Postgres (Prisma). Copy this file to ".env" and fill in real values.
# In the Neon dashboard: Project → Connection Details → Prisma.
# ----------------------------------------------------------------------------

# Pooled connection (has "-pooler" in the host) — used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# Direct connection (no "-pooler") — used only for migrations / db push.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require"

# Password that protects the /dashboard leads page and the GET /api/leads endpoint.
DASHBOARD_PASSWORD="change-me-to-a-strong-secret"
